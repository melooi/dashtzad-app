# Copy to .env and fill in real values. .env is gitignored.

# ===== App =====
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ===== Database (PostgreSQL 18) =====
# Local dev example: postgresql://<user>@localhost:5432/dashtzad?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/dashtzad?schema=public"

# ===== Auth / Session =====
# Session tokens are OPAQUE (crypto.randomBytes(32).toString('hex')), not JWT.
SESSION_COOKIE_NAME=dz_session
SESSION_TTL_DAYS=30

# ===== OTP (Kavenegar) =====
# When true, the OTP code is returned in the API response instead of sending an SMS (dev/testing).
OTP_TESTING_MODE=true
OTP_TTL_SECONDS=120
OTP_MAX_ATTEMPTS=5
# HMAC key for hashing OTP codes. Generate with: openssl rand -hex 32
OTP_SECRET=
KAVENEGAR_API_KEY=
KAVENEGAR_OTP_TEMPLATE=dashtzad-otp

# ===== Payment (ZarinPal) =====
# Get a merchant id from ZarinPal. Use sandbox for testing.
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=http://localhost:3000/api/payment/verify

# Google Search Console verification token
GOOGLE_SITE_VERIFICATION=

# ===== Chat AI copilot (CHAT-CP2) =====
# API keys for the operator "suggested reply" feature. The provider is chosen
# automatically from the model picked in admin chat settings (Claude / GPT /
# Gemini); set the key for whichever provider you use. Leave all empty to keep
# the AI copilot disabled (the button hides automatically).
#   Claude  → https://console.anthropic.com
#   GPT     → https://platform.openai.com/api-keys
#   Gemini  → https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ===== AI Assistant + Admin Analyst (AI-CP-A) =====
# Server-only. OPENAI_API_KEY above is the single key for the AI engine
# (Responses API, embeddings, moderation). Never expose it to the client.
# Models are env-tunable; defaults target the current OpenAI flagship family.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-5.5
# OPENAI_FAST_MODEL=          # cheaper model for intent/titles (defaults to chat model)
# OPENAI_ANALYST_MODEL=       # admin analyst model (defaults to chat model)
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_MODERATION_ENABLED=true
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
OPENAI_MAX_OUTPUT_TOKENS=1024
# Reasoning effort for GPT-5-family models: minimal | low | medium | high.
# Lower = faster/cheaper visible text (reasoning models spend output tokens
# thinking before they answer). "low" keeps customer chat snappy.
OPENAI_REASONING_EFFORT=low
OPENAI_TIMEOUT_MS=60000
# Optional OpenAI org/project routing headers
# OPENAI_ORG_ID=
# OPENAI_PROJECT_ID=
# Salt for hashing visitor/customer ids into a stable, non-PII safety_identifier
AI_SAFETY_ID_SALT=dashtzad-ai
