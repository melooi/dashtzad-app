// ============================================================================
// AI ASSISTANT & ADMIN ANALYST  (AI-CP-A foundation)
// New, additive domain. References to existing User / Conversation rows are
// stored as scalar IDs (no FK) so the existing models stay untouched and the
// human live-chat system is never disturbed. Relations exist only inside the
// Ai* family. Tables are mapped to the snake_case names from the spec.
// Embeddings are stored as Float[] for portability; production should upgrade
// AiVectorChunk.embedding to a pgvector `vector(N)` column + ANN index (CP-C).
// ============================================================================

model AiConversation {
  id             String               @id @default(uuid())
  channel        AiChannel            @default(STOREFRONT)
  status         AiConversationStatus @default(ACTIVE)
  sessionId      String?
  visitorId      String?
  customerId     String? // User.id of a logged-in customer (scalar, no FK)
  operatorId     String? // User.id of the operator after handoff (scalar, no FK)
  intent         String?
  priority       AiPriority           @default(NORMAL)
  tags           String[]             @default([]) // operator-applied labels (chat center)
  operatorNote   String? // internal note for operators (not shown to the customer)
  title          String?
  language       String               @default("fa")
  lastResponseId String? // OpenAI Responses API response id, for server-side chaining
  lastMessageAt  DateTime             @default(now())
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  session   AiSession?   @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  messages  AiMessage[]
  toolCalls AiToolCall[]
  handoffs  AiHandoff[]
  feedback  AiFeedback[]

  @@index([channel])
  @@index([status])
  @@index([visitorId])
  @@index([customerId])
  @@index([operatorId])
  @@index([sessionId])
  @@index([lastMessageAt])
  @@map("ai_conversations")
}

model AiSession {
  id         String    @id @default(uuid())
  token      String    @unique @default(uuid())
  channel    AiChannel @default(STOREFRONT)
  visitorId  String?
  customerId String?
  ipHash     String? // sha256 of client ip — never store raw ip
  userAgent  String?
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())

  conversations AiConversation[]

  @@index([token])
  @@index([visitorId])
  @@index([customerId])
  @@map("ai_sessions")
}

model AiMessage {
  id                 String        @id @default(uuid())
  conversationId     String
  role               AiMessageRole
  content            String // plain text body (may be "" for pure tool/structured turns)
  contentJson        Json? // structured output, tool payloads, rich content (cards)
  model              String?
  providerResponseId String? // OpenAI response id
  tokensInput        Int?
  tokensOutput       Int?
  latencyMs          Int?
  moderationFlagged  Boolean       @default(false)
  createdAt          DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolCalls    AiToolCall[]

  @@index([conversationId])
  @@index([role])
  @@index([createdAt])
  @@map("ai_messages")
}

model AiTool {
  id               String         @id @default(uuid())
  name             String         @unique
  category         AiToolCategory
  description      String
  parametersJson   Json? // JSON schema for the function tool (Responses API `tools[].parameters`)
  enabled          Boolean        @default(true)
  readOnly         Boolean        @default(true)
  requiresAuth     Boolean        @default(false)
  requiresApproval Boolean        @default(false)
  isDestructive    Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([category])
  @@index([enabled])
  @@map("ai_tools")
}

model AiToolCall {
  id             String           @id @default(uuid())
  conversationId String
  messageId      String?
  toolName       String
  providerCallId String? // OpenAI function call_id
  argumentsJson  Json?
  resultJson     Json?
  status         AiToolCallStatus @default(PENDING)
  errorMessage   String?
  latencyMs      Int?
  approvedById   String? // operator/admin User.id who approved a gated action (scalar, no FK)
  approvedAt     DateTime?
  createdAt      DateTime         @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      AiMessage?     @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([toolName])
  @@index([status])
  @@index([createdAt])
  @@map("ai_tool_calls")
}

model AiHandoff {
  id               String          @id @default(uuid())
  aiConversationId String
  conversationId   String? // bridged row in the existing operator inbox (Conversation.id, scalar)
  reason           String?
  summary          String?
  status           AiHandoffStatus @default(REQUESTED)
  priority         AiPriority      @default(NORMAL)
  operatorId       String? // User.id (scalar, no FK)
  requestedAt      DateTime        @default(now())
  resolvedAt       DateTime?
  createdAt        DateTime        @default(now())

  aiConversation AiConversation @relation(fields: [aiConversationId], references: [id], onDelete: Cascade)

  @@index([aiConversationId])
  @@index([conversationId])
  @@index([status])
  @@map("ai_handoffs")
}

model AiFeedback {
  id             String           @id @default(uuid())
  conversationId String
  messageId      String?
  rating         AiFeedbackRating
  comment        String?
  visitorId      String?
  customerId     String?
  createdAt      DateTime         @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([rating])
  @@map("ai_feedback")
}

model AiKnowledgeSource {
  id            String            @id @default(uuid())
  type          AiKnowledgeType
  externalId    String? // id in the source system (product id, faq id, ...)
  title         String
  url           String?
  status        AiKnowledgeStatus @default(ACTIVE)
  documentCount Int               @default(0)
  lastIndexedAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  documents AiVectorDocument[]

  @@unique([type, externalId])
  @@index([type])
  @@index([status])
  @@map("ai_knowledge_sources")
}

model AiVectorDocument {
  id           String          @id @default(uuid())
  sourceId     String
  sourceType   AiKnowledgeType
  externalId   String?
  title        String
  url          String?
  contentHash  String? // skip re-embedding when unchanged
  metadataJson Json?
  chunkCount   Int             @default(0)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  source AiKnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  chunks AiVectorChunk[]

  @@index([sourceId])
  @@index([sourceType])
  @@map("ai_vector_documents")
}

model AiVectorChunk {
  id             String   @id @default(uuid())
  documentId     String
  chunkIndex     Int      @default(0)
  content        String
  tokenCount     Int?
  embedding      Float[] // cosine similarity in-app; pgvector `vector(N)` in production (CP-C)
  embeddingModel String?
  dim            Int?
  metadataJson   Json?
  createdAt      DateTime @default(now())

  document AiVectorDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("ai_vector_chunks")
}

model AiAdminReport {
  id               String         @id @default(uuid())
  title            String
  status           AiReportStatus @default(PENDING)
  executiveSummary String?
  scopeJson        Json?
  modules          String[]
  model            String?
  tokensInput      Int            @default(0)
  tokensOutput     Int            @default(0)
  generatedById    String? // admin User.id (scalar, no FK)
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  findings AiAdminFinding[]

  @@index([status])
  @@index([createdAt])
  @@map("ai_admin_reports")
}

model AiAdminFinding {
  id              String          @id @default(uuid())
  reportId        String
  module          String
  severity        AiSeverity
  title           String
  description     String
  evidenceJson    Json?
  recommendation  String
  suggestedAction String?
  status          AiFindingStatus @default(OPEN)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  report AiAdminReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([severity])
  @@index([status])
  @@index([module])
  @@map("ai_admin_findings")
}

model AiGuardrailEvent {
  id             String            @id @default(uuid())
  conversationId String?
  messageId      String?
  type           AiGuardrailType
  action         AiGuardrailAction
  severity       AiSeverity?
  detailsJson    Json?
  createdAt      DateTime          @default(now())

  @@index([conversationId])
  @@index([type])
  @@index([createdAt])
  @@map("ai_guardrail_events")
}

model AiUsageLog {
  id             String      @id @default(uuid())
  conversationId String?
  messageId      String?
  operation      AiOperation
  model          String
  tokensInput    Int         @default(0)
  tokensOutput   Int         @default(0)
  totalTokens    Int         @default(0)
  latencyMs      Int?
  costMicroUsd   Int? // estimated cost in micro-USD (integer)
  success        Boolean     @default(true)
  requestId      String? // OpenAI x-request-id
  createdAt      DateTime    @default(now())

  @@index([conversationId])
  @@index([operation])
  @@index([model])
  @@index([createdAt])
  @@map("ai_usage_logs")
}

model AiErrorLog {
  id             String       @id @default(uuid())
  conversationId String?
  operation      AiOperation?
  model          String?
  code           String?
  message        String
  detailsJson    Json?
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@map("ai_error_logs")
}

