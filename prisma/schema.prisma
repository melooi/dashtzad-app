generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String                   @id @default(uuid())
  phoneNumber           String                   @unique
  name                  String?
  email                 String?                  @unique
  avatar                String?
  biography             String?
  role                  Role                     @default(USER)
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  birthDate             DateTime?
  nationalId            String?
  chatLastSeenAt        DateTime?
  chatOnline            Boolean                  @default(false)
  accounts              Account[]
  addresses             Address[]
  cart                  Cart?
  chatMessages          ChatMessage[]
  assignedConversations Conversation[]           @relation("AssignedConversations")
  conversations         Conversation[]           @relation("VisitorConversations")
  authoredCustomerNotes CustomerNote[]           @relation("CustomerNotesAuthor")
  customerNotes         CustomerNote[]           @relation("CustomerNotesSubject")
  media                 MediaAsset[]
  orders                Order[]
  payments              Payment[]
  posts                 Post[]
  comments              PostComment[]
  postLikes             PostLike[]
  postRatings           PostRating[]
  answeredQuestions     ProductQuestion[]        @relation("AdminAnsweredQuestions")
  questions             ProductQuestion[]        @relation("UserQuestions")
  reviews               ProductReview[]
  recentViews           RecentProductView[]
  sessions              Session[]
  adminCreditEntries    StoreCreditTransaction[] @relation("AdminCreditEntries")
  creditTransactions    StoreCreditTransaction[] @relation("UserCredit")
  wishlist              WishlistItem[]
  departments           Department[]             @relation("DepartmentOperators")

  @@index([phoneNumber])
}

model Account {
  id                String   @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  userAgent String?
  ip        String?
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}

model OtpCode {
  id           String    @id @default(uuid())
  phoneNumber  String
  codeHash     String
  expiresAt    DateTime
  consumedAt   DateTime?
  attemptCount Int       @default(0)
  resendCount  Int       @default(0)
  ip           String?
  userAgent    String?
  createdAt    DateTime  @default(now())

  @@index([phoneNumber])
  @@index([expiresAt])
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  receiverName String
  phone        String
  province     String
  city         String
  postalCode   String
  line         String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deliveryNote String?
  plaque       String?
  title        String?
  unit         String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([userId])
}

model Category {
  id           String       @id @default(uuid())
  title        String
  slug         String       @unique
  englishTitle String?
  description  String?
  type         CategoryType
  parentId     String?
  iconSm       String?
  iconLg       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  parent       Category?    @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryTree")
  posts        Post[]
  products     Product[]

  @@index([slug])
  @@index([type])
  @@index([parentId])
}

model Product {
  id                 String              @id @default(uuid())
  title              String
  slug               String              @unique
  description        String
  brand              String?
  price_rial         Int
  offPrice_rial      Int?
  discountPercent    Int                 @default(0)
  countInStock       Int                 @default(0)
  rating             Float               @default(0)
  numReviews         Int                 @default(0)
  tags               String[]
  isActive           Boolean             @default(true)
  categoryId         String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  basePriceUnit      ProductBaseUnit     @default(GRAM)
  basePrice_rial     Int?
  story              String?
  contactPhone       String?
  installmentEnabled Boolean             @default(false)
  saleMode           SaleMode            @default(AUTO)
  latinTitle         String?
  pdpContent         Json?
  cartItems          CartItem[]
  orderItems         OrderItem[]
  category           Category            @relation(fields: [categoryId], references: [id])
  images             ProductImage[]
  questions          ProductQuestion[]
  reviews            ProductReview[]
  variants           ProductVariant[]
  recentViews        RecentProductView[]
  wishlistItems      WishlistItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  url       String
  alt       String?
  sortOrder Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model WeightPreset {
  id            String           @id @default(uuid())
  title         String
  gramValue     Float
  compatibility String[]
  sortOrder     Int              @default(0)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  variants      ProductVariant[]

  @@index([isActive])
}

model PackagingOption {
  id            String           @id @default(uuid())
  title         String
  type          PackagingType
  capacityGram  Float
  cost_rial     Int
  compatibility String[]
  sortOrder     Int              @default(0)
  isActive      Boolean          @default(true)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  variants      ProductVariant[]

  @@index([isActive])
}

model ProductVariant {
  id                   String           @id @default(uuid())
  productId            String
  weightPresetId       String?
  packagingOptionId    String?
  weightValue          Float
  weightUnit           ProductBaseUnit  @default(GRAM)
  gramValue            Float
  sku                  String           @unique
  calculatedPrice_rial Int
  price_rial           Int
  offPrice_rial        Int?
  stock                Int              @default(0)
  isActive             Boolean          @default(true)
  isPriceLocked        Boolean          @default(false)
  marketingBadge       MarketingBadge?
  sortOrder            Int              @default(0)
  imageUrl             String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  cartItems            CartItem[]
  orderItems           OrderItem[]
  packaging            PackagingOption? @relation(fields: [packagingOptionId], references: [id])
  product              Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  weight               WeightPreset?    @relation(fields: [weightPresetId], references: [id])

  @@index([productId])
  @@index([sku])
  @@index([isActive])
}

model Cart {
  id        String     @id @default(uuid())
  userId    String     @unique
  couponId  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([userId])
}

model CartItem {
  id               String          @id @default(uuid())
  cartId           String
  productId        String
  quantity         Int             @default(1)
  productVariantId String?
  cart             Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id])
  variant          ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@unique([cartId, productId])
  @@index([cartId])
  @@index([productId])
  @@index([productVariantId])
}

model Order {
  id            String               @id @default(uuid())
  orderNumber   String               @unique
  userId        String
  status        OrderStatus          @default(PENDING)
  addressId     String?
  couponId      String?
  subtotal_rial Int
  discount_rial Int                  @default(0)
  shipping_rial Int                  @default(0)
  total_rial    Int
  note          String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  trackingCode  String?
  address       Address?             @relation(fields: [addressId], references: [id])
  coupon        Coupon?              @relation(fields: [couponId], references: [id])
  user          User                 @relation(fields: [userId], references: [id])
  items         OrderItem[]
  statusHistory OrderStatusHistory[]
  payment       Payment?
  reviews       ProductReview[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
}

model OrderItem {
  id               String          @id @default(uuid())
  orderId          String
  productId        String
  title            String
  unitPrice_rial   Int
  quantity         Int
  lineTotal_rial   Int
  productVariantId String?
  variantSku       String?
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id])
  variant          ProductVariant? @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@index([productVariantId])
}

model OrderStatusHistory {
  id        String      @id @default(uuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  userId      String
  provider    String        @default("ZARINPAL")
  amount_rial Int
  status      PaymentStatus @default(PENDING)
  authority   String?
  refId       String?
  cardPan     String?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([authority])
}

model Coupon {
  id               String     @id @default(uuid())
  code             String     @unique
  type             CouponType
  amount           Int
  maxDiscount_rial Int?
  minOrder_rial    Int?
  expiresAt        DateTime
  isActive         Boolean    @default(true)
  usageLimit       Int
  usageCount       Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  description      String?
  firstOrderOnly   Boolean    @default(false)
  perUserLimit     Int?
  startsAt         DateTime?
  title            String?
  carts            Cart[]
  orders           Order[]

  @@index([code])
  @@index([expiresAt])
}

model Post {
  id                String             @id @default(uuid())
  title             String
  slug              String             @unique
  type              PostType           @default(FREE)
  status            PostStatus         @default(DRAFT)
  briefText         String
  text              String
  coverImage        String
  readingTime       Int
  tags              String[]
  viewCount         Int                @default(0)
  authorId          String
  categoryId        String
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  adminNote         String?
  articleType       ArticleType?
  publishedAt       DateTime?
  relatedPostIds    String[]
  relatedProductIds String[]
  seriesId          String?
  seriesOrder       Int?
  sources           Json?
  subtitle          String?
  typeMeta          Json?
  recipeMeta        Json?
  author            User               @relation(fields: [authorId], references: [id])
  category          Category           @relation(fields: [categoryId], references: [id])
  series            ContentSeries?     @relation(fields: [seriesId], references: [id])
  comments          PostComment[]
  likes             PostLike[]
  ratings           PostRating[]
  guestRatings      RecipeGuestRating[]
  suggestions       RecipeSuggestion[]

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([articleType])
  @@index([seriesId])
}

model ContentSeries {
  id         String     @id @default(uuid())
  title      String
  slug       String     @unique
  subtitle   String?
  summary    String?
  coverImage String?
  intro      String?
  keyTopics  String[]
  status     PostStatus @default(DRAFT)
  sortOrder  Int        @default(0)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  posts      Post[]

  @@index([slug])
  @@index([status])
}

model PostComment {
  id        String        @id @default(uuid())
  userId    String
  postId    String
  parentId  String?
  text      String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  parent    PostComment?  @relation("Replies", fields: [parentId], references: [id])
  replies   PostComment[] @relation("Replies")
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id])

  @@index([postId])
  @@index([userId])
  @@index([parentId])
  @@index([status])
}

// Logged-in user rating (RECIPE-CP1) — userId REQUIRED (not weakened). Moderated:
// only status=APPROVED rows affect the public aggregate.
model PostRating {
  id                String       @id @default(uuid())
  userId            String
  postId            String
  value             Int // 1..5
  status            RatingStatus @default(PENDING)
  source            RatingSource @default(USER)
  feedbackText      String? // optional reviewer feedback (low ratings)
  feedbackReasons   String[]     @default([]) // selected reason keys
  reviewedAt        DateTime?
  reviewedByAdminId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  post              Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  user              User         @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
  @@index([postId])
  @@index([status])
}

// Guest (anonymous) rating (RECIPE-CP1) — kept SEPARATE from PostRating so the
// logged-in model stays strict. Identifiable for moderation via a hashed guest
// key; one row per (post, guest). Only status=APPROVED affects the aggregate.
model RecipeGuestRating {
  id                String       @id @default(uuid())
  postId            String
  value             Int // 1..5
  feedbackText      String?
  feedbackReasons   String[]     @default([])
  guestName         String?
  guestPhone        String?
  guestKeyHash      String // sha256(guestKey) — server-side
  status            RatingStatus @default(PENDING)
  source            RatingSource @default(GUEST)
  reviewedAt        DateTime?
  reviewedByAdminId String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  post              Post         @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, guestKeyHash])
  @@index([postId])
  @@index([status])
}

model PostLike {
  id        String   @id @default(uuid())
  userId    String?
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id])

  @@unique([userId, postId])
  @@index([postId])
}

model RecipeSuggestion {
  id        String        @id @default(uuid())
  postId    String
  name      String
  phone     String
  text      String
  status    CommentStatus @default(PENDING)
  createdAt DateTime      @default(now())
  post      Post          @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([status])
}

model ProductReview {
  id               String       @id @default(uuid())
  userId           String
  productId        String
  orderId          String?
  rating           Int
  title            String?
  text             String
  verifiedPurchase Boolean      @default(false)
  status           ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  order            Order?       @relation(fields: [orderId], references: [id])
  product          Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  user             User         @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
  @@index([productId])
  @@index([userId])
  @@index([status])
}

model GlobalSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model Menu {
  id        String       @id @default(uuid())
  title     String
  slug      String       @unique
  location  MenuLocation @default(CUSTOM)
  isActive  Boolean      @default(true)
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  items     MenuItem[]

  @@index([slug])
  @@index([location])
}

model MenuItem {
  id             String       @id @default(uuid())
  menuId         String
  parentId       String?
  label          String
  href           String
  linkType       MenuLinkType @default(CUSTOM)
  target         LinkTarget   @default(SELF)
  icon           String?
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  badge          String?
  description    String?
  desktopVisible Boolean      @default(true)
  mobileVisible  Boolean      @default(true)
  menu           Menu         @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent         MenuItem?    @relation("MenuItemTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       MenuItem[]   @relation("MenuItemTree")

  @@index([menuId])
  @@index([parentId])
}

model Banner {
  id             String          @id @default(uuid())
  title          String
  slug           String          @unique
  subtitle       String?
  description    String?
  imageUrl       String?
  mobileImageUrl String?
  linkLabel      String?
  linkHref       String?
  placement      BannerPlacement @default(HOME_HERO)
  startsAt       DateTime?
  endsAt         DateTime?
  isActive       Boolean         @default(true)
  sortOrder      Int             @default(0)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([placement])
  @@index([isActive])
  @@index([slug])
}

model FAQGroup {
  id          String       @id @default(uuid())
  title       String
  slug        String       @unique
  description String?
  placement   FAQPlacement @default(GENERAL)
  isActive    Boolean      @default(true)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  items       FAQItem[]

  @@index([placement])
  @@index([slug])
}

model FAQItem {
  id        String   @id @default(uuid())
  groupId   String
  question  String
  answer    String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  group     FAQGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model Redirect {
  id          String   @id @default(uuid())
  source      String   @unique
  destination String
  statusCode  Int      @default(301)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([source])
  @@index([isActive])
}

model SeoMeta {
  id                 String        @id @default(uuid())
  entityType         SeoEntityType
  entityId           String
  title              String?
  description        String?
  canonicalUrl       String?
  ogTitle            String?
  ogDescription      String?
  ogImageUrl         String?
  twitterTitle       String?
  twitterDescription String?
  twitterImageUrl    String?
  noindex            Boolean       @default(false)
  nofollow           Boolean       @default(false)
  schemaOverride     Json?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@unique([entityType, entityId])
  @@index([entityType])
}

model MediaAsset {
  id           String       @id @default(uuid())
  filename     String
  originalName String
  mimeType     String
  sizeBytes    Int
  width        Int?
  height       Int?
  alt          String?
  title        String?
  caption      String?
  storage      MediaStorage @default(LOCAL)
  path         String
  url          String
  publicId     String?
  folder       String?
  tags         String[]
  usage        MediaUsage?
  uploadedById String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])

  @@index([mimeType])
  @@index([storage])
  @@index([usage])
  @@index([createdAt])
}

model Conversation {
  id                 String             @id @default(uuid())
  publicToken        String             @unique @default(uuid())
  status             ConversationStatus @default(NEW)
  source             String             @default("storefront")
  subject            String?
  userId             String?
  guestName          String?
  guestPhone         String?
  assignedToId       String?
  lastMessageAt      DateTime           @default(now())
  lastMessagePreview String?
  unreadForAdmin     Int                @default(0)
  unreadForVisitor   Int                @default(0)
  resolvedAt         DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  departmentId       String?
  ratedAt            DateTime?
  rating             Int?
  ratingComment      String?
  messages           ChatMessage[]
  assignedTo         User?              @relation("AssignedConversations", fields: [assignedToId], references: [id])
  department         Department?        @relation(fields: [departmentId], references: [id])
  user               User?              @relation("VisitorConversations", fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
  @@index([assignedToId])
  @@index([departmentId])
  @@index([lastMessageAt])
  @@index([publicToken])
}

model ChatMessage {
  id             String         @id @default(uuid())
  conversationId String
  senderRole     ChatSenderRole
  body           String
  authorId       String?
  createdAt      DateTime       @default(now())
  attachmentMime String?
  attachmentName String?
  attachmentSize Int?
  attachmentUrl  String?
  isInternalNote Boolean        @default(false)
  author         User?          @relation(fields: [authorId], references: [id])
  conversation   Conversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
}

model Department {
  id            String         @id @default(uuid())
  name          String
  color         String?
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  operators     User[]         @relation("DepartmentOperators")

  @@index([isActive])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model RecentProductView {
  id        String   @id @default(uuid())
  userId    String
  productId String
  viewedAt  DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([viewedAt])
}

model StoreCreditTransaction {
  id               String               @id @default(uuid())
  userId           String
  amount_rial      Int
  type             StoreCreditType
  direction        StoreCreditDirection
  reason           String?
  expiresAt        DateTime?
  createdByAdminId String?
  createdAt        DateTime             @default(now())
  createdBy        User?                @relation("AdminCreditEntries", fields: [createdByAdminId], references: [id])
  user             User                 @relation("UserCredit", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model ProductQuestion {
  id           String         @id @default(uuid())
  userId       String
  productId    String
  question     String
  answer       String?
  answeredById String?
  answeredAt   DateTime?
  status       QuestionStatus @default(PENDING)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  answeredBy   User?          @relation("AdminAnsweredQuestions", fields: [answeredById], references: [id])
  product      Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  user         User           @relation("UserQuestions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
  @@index([status])
}

model CustomerNote {
  id        String   @id @default(uuid())
  userId    String
  authorId  String
  body      String
  createdAt DateTime @default(now())
